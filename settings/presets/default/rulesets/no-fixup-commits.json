{
  "rulesets": [
    {
      "name": "No Fixup Commits",
      "target": "branch",
      "enforcement": "active",
      "bypass_actors": [],
      "conditions": {
        "ref_name": {
          "include": ["~DEFAULT_BRANCH"],
          "exclude": []
        }
      },
      "rules": [
        {
          "type": "required_status_checks",
          "parameters": {
            "required_status_checks": [
              { "context": "no-fixup-commits" }
            ],
            "strict_required_status_checks_policy": true,
            "do_not_enforce_on_create": true
          }
        }
      ]
    }
  ]
}
